FROM vllm/vllm-openai:latest

ENV MODEL_NAME="Qwen/Qwen3.5-9B"
ENV MAX_MODEL_LEN=8192
ENV GPU_MEM_UTIL=0.90
ENV EXTRA_ARGS=""

EXPOSE 8080

ENTRYPOINT []
CMD ["sh", "-c", "python3 -m vllm.entrypoints.openai.api_server --model $MODEL_NAME --host 0.0.0.0 --port 8080 --max-model-len $MAX_MODEL_LEN --gpu-memory-utilization $GPU_MEM_UTIL --reasoning-parser qwen3 --enable-prefix-caching $EXTRA_ARGS"]
